                f.write(linha_caixa(f"   TOTAL GERAL ({e.qtd} unidades): {peso_total_estaca:.2f} kg"))
                f.write(linha_vazia_caixa())
                
                # Recomendações Técnicas (se for Hélice Contínua)
                if e.tipo == "Hélice Contínua":
