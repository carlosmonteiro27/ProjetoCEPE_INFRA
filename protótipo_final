                f.write(linha_caixa(f"   • Comprimento Armado: {e.l_arm:.2f} m"))
                f.write(linha_caixa(f"   • Arranque: {e.arranque:.2f} m"))
                f.write(linha_caixa(f"   • Cobrimento: {e.cobrimento_cm:.1f} cm ({e.cobrimento:.3f} m)"))
                f.write(linha_caixa(f"   • Diâmetro da Armadura: {e.d_arm:.3f} m"))
                f.write(linha_vazia_caixa())
                
                # Armadura Longitudinal
                f.write(linha_caixa(" ARMADURA LONGITUDINAL (N1):"))
                f.write(linha_vazia_caixa())
                if e.longitudinal:
                    for long in e.longitudinal:
                        f.write(linha_caixa(f"   • Quantidade de Barras: {long['n']}"))
                        f.write(linha_caixa(f"   • Diâmetro: Ø {long['phi']:.1f} mm"))
                        comprimento_unit = e.l_arm + e.arranque
                        comprimento_total = long['n'] * comprimento_unit * e.qtd
                        f.write(linha_caixa(f"   • Comprimento por Barra: {e.l_arm:.2f} m (armado) + {e.arranque:.2f} m (arranque) = {comprimento_unit:.2f} m"))
                        f.write(linha_caixa(f"   • Comprimento Total: {comprimento_total:.2f} m"))
                        peso_linear = TABELA_ACO.get(long['phi'], 0)
                        peso_total_long = comprimento_total * peso_linear * 1.10
                        f.write(linha_caixa(f"   • Peso Linear: {peso_linear:.3f} kg/m"))
                        f.write(linha_caixa(f"   • Peso Total (c/ 10% perda): {peso_total_long:.2f} kg"))
                else:
                    f.write(linha_caixa("   • Não especificada"))
                f.write(linha_vazia_caixa())
                
                # Armadura Transversal
                f.write(linha_caixa(" ARMADURA TRANSVERSAL (N2):"))
                f.write(linha_vazia_caixa())
                if e.transversal:
