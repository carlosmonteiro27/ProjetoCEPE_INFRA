LARGURA_TOTAL_CAIXA = 100          # largura total da linha com bordas
LARGURA_INTERNA_CAIXA = 98        # largura útil entre as bordas verticais

def linha_caixa(conteudo: str = "") -> str:
    """
    Gera uma linha do tipo: │ conteudo...                 │
    garantindo que a borda direita fique sempre alinhada.
    """
    texto = (conteudo or "")[:LARGURA_INTERNA_CAIXA]
    espacos = LARGURA_INTERNA_CAIXA - len(texto)
    return f"│{texto}{' ' * espacos}│\n"

def linha_caixa_centrada(conteudo: str = "") -> str:
    """Linha com texto centralizado entre as bordas."""
    texto = (conteudo or "")[:LARGURA_INTERNA_CAIXA]
    return f"│{texto.center(LARGURA_INTERNA_CAIXA)}│\n"

def linha_vazia_caixa() -> str:
    """Linha vazia dentro da caixa."""
    return linha_caixa("")

def salvar_click():
    if not lista_estacas:
        messagebox.showwarning("Atenção", "Nenhuma estaca para exportar!")
        return
    
    try:
        import datetime
        timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        nome_sugerido = f"Relatorio_Tecnico_SysInfra_{timestamp}.txt"

        # Abre diálogo para o usuário escolher onde salvar
        nome_arquivo = filedialog.asksaveasfilename(
            title="Salvar Relatório Técnico",
            initialfile=nome_sugerido,
            defaultextension=".txt",
            filetypes=[("Arquivo de Texto", "*.txt"), ("Todos os Arquivos", "*.*")]
        )

        # Se o usuário cancelar o diálogo, interrompe sem erro
        if not nome_arquivo:
            return

        with open(nome_arquivo, "w", encoding="utf-8") as f:
            # CABEÇALHO (LINHA DUPLA, TUDO COM MESMA LARGURA)
            f.write("═" * LARGURA_TOTAL_CAIXA + "\n")
            f.write("╔" + "═" * LARGURA_INTERNA_CAIXA + "╗\n")
            f.write("║" + " " * LARGURA_INTERNA_CAIXA + "║\n")
            f.write("║" + "RELATÓRIO TÉCNICO DE FUNDAÇÕES PROFUNDAS".center(LARGURA_INTERNA_CAIXA) + "║\n")
            f.write("║" + "Sistema SysInfra - Dimensionamento e Quantificação".center(LARGURA_INTERNA_CAIXA) + "║\n")
            f.write("║" + " " * LARGURA_INTERNA_CAIXA + "║\n")
            f.write("╚" + "═" * LARGURA_INTERNA_CAIXA + "╝\n")
            f.write("═" * LARGURA_TOTAL_CAIXA + "\n\n")
            
            # INFORMAÇÕES DO PROJETO
            f.write("┌" + "─" * LARGURA_INTERNA_CAIXA + "┐\n")
            f.write(linha_caixa(" DADOS DO PROJETO"))
            f.write("├" + "─" * LARGURA_INTERNA_CAIXA + "┤\n")
            f.write(linha_caixa(" Instituição: Instituto Tecnológico de Aeronáutica (ITA)"))
