                        f.write(linha_caixa(f"   • N2 Comprimento: {rec['compr_n2']}"))
                        f.write(linha_caixa(f"   • N2 Transpasse: {rec['transpasse_n2']}"))
                        f.write(linha_caixa(f"   • N3 Recomendado: Anel Ø {rec['n3_phi']:.1f} mm"))
                        f.write(linha_caixa(f"   • N3 Comprimento: {rec['compr_n3']}"))
                        f.write(linha_caixa(f"   • N3 Transpasse: {rec['transpasse_n3']}"))
                        f.write(linha_vazia_caixa())
                
                f.write("└" + "─" * LARGURA_INTERNA_CAIXA + "┘\n\n")
            
            # OBSERVAÇÕES TÉCNICAS
            f.write("=" * LARGURA_TOTAL_CAIXA + "\n")
